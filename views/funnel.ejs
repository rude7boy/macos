<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paulinho dos Leilões — Como posso te ajudar?</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #D4AF37;
            --gold-hover: #B5952F;
            --dark: #0a0f1e;
            --card: #141c2e;
            --card-border: rgba(212,175,55,0.15);
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--dark);
            color: white;
            min-height: 100vh;
            min-height: 100dvh;
            overflow-x: hidden;
        }
        /* Animated background */
        body::before {
            content: '';
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(ellipse at 20% 50%, rgba(212,175,55,0.04) 0%, transparent 50%),
                        radial-gradient(ellipse at 80% 20%, rgba(59,130,246,0.04) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }
        .container { position: relative; z-index: 1; }

        /* Steps */
        .step { display: none; animation: fadeUp 0.35s ease; }
        .step.active { display: block; }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Progress */
        .progress-bar { transition: width 0.4s ease; }

        /* Pulse glow for CTA */
        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 0 0 0 rgba(212,175,55,0.4); }
            50%       { box-shadow: 0 0 0 12px rgba(212,175,55,0); }
        }
        .btn-gold-pulse { animation: pulseGlow 2s infinite; }

        /* Stat counter cards */
        .stat-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 14px;
            padding: 10px 8px;
            text-align: center;
            flex: 1;
        }
        @media (min-width: 640px) {
            .stat-card { padding: 14px 10px; }
        }
        .stat-number {
            font-size: 26px;
            font-weight: 900;
            background: linear-gradient(135deg, #D4AF37, #f5d87a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
            letter-spacing: -1px;
        }

        /* Avatar stack */
        .avatar-stack { display: flex; }
        .avatar-stack img, .avatar-stack div {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--dark);
            margin-left: -8px;
            flex-shrink: 0;
        }
        .avatar-stack div {
            background: linear-gradient(135deg, #D4AF37, #B5952F);
            color: black;
            font-size: 9px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Product Cards */
        .product-card {
            background: var(--card);
            border: 1.5px solid rgba(255,255,255,0.07);
            border-radius: 16px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.22s ease;
            position: relative;
            overflow: hidden;
        }
        .product-card::before {
            content: '';
            position: absolute;
            inset: 0;
            opacity: 0;
            transition: opacity 0.22s ease;
        }
        .product-card:hover { border-color: rgba(212,175,55,0.4); transform: translateY(-2px); }
        .product-card.selected { border-color: var(--gold); background: rgba(212,175,55,0.08); }
        .product-card.selected::after {
            content: '\f00c';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            top: 12px;
            right: 12px;
            width: 22px;
            height: 22px;
            background: var(--gold);
            color: black;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            line-height: 22px;
            text-align: center;
        }

        /* Option pill (morar/investir) */
        .option-pill {
            background: var(--card);
            border: 1.5px solid rgba(255,255,255,0.07);
            border-radius: 12px;
            padding: 18px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: center;
        }
        .option-pill:hover { border-color: rgba(212,175,55,0.4); }
        .option-pill.selected { border-color: var(--gold); background: rgba(212,175,55,0.1); }

        /* Gold button */
        .btn-gold {
            background: linear-gradient(135deg, #D4AF37, #B5952F);
            color: black;
            font-weight: 700;
            border-radius: 12px;
            padding: 16px 24px;
            width: 100%;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            font-size: 16px;
            font-family: inherit;
        }
        .btn-gold:hover { filter: brightness(1.1); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(212,175,55,0.3); }
        .btn-gold:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

        /* Input */
        .field-input {
            width: 100%;
            background: var(--card);
            border: 1.5px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 14px 16px;
            color: white;
            font-size: 16px;
            font-family: inherit;
            outline: none;
            transition: border-color 0.2s;
        }
        .field-input:focus { border-color: var(--gold); }
        .field-input::placeholder { color: rgba(255,255,255,0.3); }

        /* Back link */
        .btn-back {
            color: rgba(255,255,255,0.4);
            font-size: 14px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: color 0.2s;
            background: none;
            border: none;
            font-family: inherit;
        }
        .btn-back:hover { color: white; }

        /* Badge tag */
        .badge {
            display: inline-block;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Featured cards (Licenciado + Promotor) */
        .featured-card {
            border-color: rgba(251, 191, 36, 0.25) !important;
            background: rgba(251, 191, 36, 0.04);
        }
        .featured-card:hover {
            border-color: rgba(251, 191, 36, 0.6) !important;
            background: rgba(251, 191, 36, 0.08);
            transform: translateY(-2px);
        }
        .promotor-card {
            border-color: rgba(212, 175, 55, 0.35) !important;
            background: linear-gradient(135deg, rgba(212,175,55,0.06), rgba(212,175,55,0.02));
            box-shadow: 0 0 20px rgba(212,175,55,0.06);
        }
        .promotor-card:hover {
            box-shadow: 0 4px 24px rgba(212,175,55,0.15);
        }

        /* Compact grid cards (2x2) */
        .compact-card {
            padding: 16px 12px !important;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .compact-card:hover { border-color: rgba(255,255,255,0.2); }

        /* Range cards (capital investidor) */
        .compact-range { padding: 14px 16px !important; }
        .compact-range:hover { border-color: rgba(255,255,255,0.18); }
    </style>
</head>
<body>

<!-- Progress Bar -->
<div class="fixed top-0 left-0 w-full h-1 bg-slate-800 z-50">
    <div id="progressBar" class="progress-bar h-full bg-gradient-to-r from-yellow-500 to-yellow-300 w-0"></div>
</div>

<div class="container min-h-screen flex items-center justify-center px-4 py-2 sm:py-12 mx-auto">
    <div class="w-full max-w-lg">

        <!-- Logo Removida -->


        <form id="funnelForm">

            <!-- ===== STEP 1: INTRO ===== -->
            <div class="step active" data-step="1">

                <!-- Headline principal -->
                <div class="text-center mb-2 sm:mb-6">
                    <h1 class="text-2xl sm:text-4xl font-black text-white leading-[1.1] mb-2 sm:mb-3 tracking-tight">
                        Imóvel de leilão<br>
                        <span style="background: linear-gradient(135deg, #D4AF37, #f5d87a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">com quem mais arrematou</span><br>
                        no Brasil.
                    </h1>
                    <p class="text-slate-400 text-[13px] sm:text-base leading-relaxed max-w-sm mx-auto">
                        Mais de <strong class="text-white">1.000 alunos formados</strong> e <strong class="text-white">1.000 arrematações</strong> realizadas com a nossa metodologia.
                    </p>
                </div>

                <!-- Stats em linha -->
                <div class="flex gap-2 sm:gap-3 mb-3 sm:mb-5">
                    <div class="stat-card flex-1">
                        <p class="stat-number" id="countAlunos">0</p>
                        <p class="text-[11px] text-slate-500 mt-1 font-medium">Alunos</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-number" id="countArremates">0</p>
                        <p class="text-[11px] text-slate-500 mt-1 font-medium">Arrematações</p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-number">Suporte</p>
                        <p class="text-[11px] text-slate-500 mt-1 font-medium">Individual e Dedicado</p>
                    </div>
                </div>

                <!-- Prova social: avatares -->
                <div class="flex items-center gap-3 mb-3 sm:mb-6 bg-white/3 border border-white/6 rounded-xl px-4 py-2 sm:py-3">
                    <div class="avatar-stack ml-2">
                        <div>AG</div>
                        <div>MR</div>
                        <div>FS</div>
                        <div>LT</div>
                        <div>+</div>
                    </div>
                    <p class="text-[10px] sm:text-xs text-slate-400 leading-tight">
                        <span class="text-white font-semibold">Mais de 1.000 pessoas</span> já transformaram
                        seu patrimônio com o Paulinho.
                    </p>
                </div>

                <button type="button" onclick="nextStep(2)" class="btn-gold btn-gold-pulse">
                    Quero saber como <i class="fa-solid fa-arrow-right ml-2"></i>
                </button>

                <p class="text-center text-[11px] text-slate-600 mt-2">
                    <i class="fa-solid fa-lock mr-1"></i> Seus dados são 100% seguros e confidenciais
                </p>
            </div>

            <!-- ===== STEP 2: INTERESSE (produto) ===== -->
            <div class="step" data-step="2">
                <h2 class="text-2xl font-bold mb-1 text-white">Como posso te ajudar?</h2>
                <p class="text-slate-400 mb-5 text-sm">Escolha uma opção abaixo.</p>

                <input type="hidden" name="interesse" id="interesseInput">
                <input type="hidden" name="objetivo" id="objetivoInput">

                <!-- ⭐ DESTAQUE: Licenciado + Promotor -->
                <p class="text-[10px] font-bold uppercase tracking-widest text-yellow-500/80 mb-3">
                    <i class="fa-solid fa-fire mr-1"></i> Mais procurado
                </p>
                <div class="space-y-2 mb-4">

                    <!-- Licenciado FEATURED -->
                    <div class="product-card featured-card" onclick="selectInteresse(this, 'licenciado')">
                        <div class="flex items-center gap-4">
                            <div class="w-11 h-11 rounded-xl bg-amber-500/15 flex items-center justify-center flex-shrink-0">
                                <i class="fa-solid fa-id-badge text-amber-400 text-lg"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2">
                                    <span class="font-bold text-white">Licenciado</span>
                                    <span class="badge bg-amber-500/15 text-amber-400 border border-amber-500/30">Parceiro</span>
                                </div>
                                <p class="text-xs text-slate-400 mt-0.5 leading-relaxed">Acompanha clientes do 1º contato ao arremate — captação, lance e pós-arremate.</p>
                            </div>
                            <i class="fa-solid fa-chevron-right text-amber-400/50 text-xs flex-shrink-0"></i>
                        </div>
                    </div>

                    <!-- Promotor FEATURED -->
                    <div class="product-card featured-card promotor-card" onclick="selectInteresse(this, 'promotor')">
                        <div class="flex items-center gap-4">
                            <div class="w-11 h-11 rounded-xl bg-yellow-500/15 flex items-center justify-center flex-shrink-0">
                                <i class="fa-solid fa-crown text-yellow-400 text-lg"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2">
                                    <span class="font-bold text-white">Promotor Oficial</span>
                                    <span class="badge bg-yellow-500/15 text-yellow-400 border border-yellow-500/30">Exclusivo</span>
                                </div>
                                <p class="text-xs text-slate-400 mt-0.5 leading-relaxed">Representante oficial na sua região — máxima autoridade da marca.</p>
                            </div>
                            <i class="fa-solid fa-chevron-right text-yellow-400/50 text-xs flex-shrink-0"></i>
                        </div>
                    </div>
                </div>

                <!-- Outras opções em grid compacto -->
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-3">Outras opções</p>
                <div class="grid grid-cols-2 gap-2 mb-4">

                    <div class="product-card compact-card" onclick="selectInteresse(this, 'assessoria')">
                        <i class="fa-solid fa-handshake text-blue-400 mb-2 text-lg"></i>
                        <p class="font-semibold text-white text-sm">Assessoria</p>
                        <p class="text-[11px] text-slate-500 mt-0.5">Comprar imóvel em leilão</p>
                    </div>

                    <div class="product-card compact-card" onclick="selectInteresse(this, 'mentoria_individual')">
                        <i class="fa-solid fa-user-tie text-emerald-400 mb-2 text-lg"></i>
                        <p class="font-semibold text-white text-sm">Mentoria Individual</p>
                        <p class="text-[11px] text-slate-500 mt-0.5">Atendimento exclusivo</p>
                    </div>

                    <div class="product-card compact-card" onclick="selectInteresse(this, 'mentoria_online')">
                        <i class="fa-solid fa-laptop text-purple-400 mb-2 text-lg"></i>
                        <p class="font-semibold text-white text-sm">Mentoria Online</p>
                        <p class="text-[11px] text-slate-500 mt-0.5">Aprender no meu ritmo</p>
                    </div>

                    <div class="product-card compact-card" onclick="selectInteresse(this, 'eventos')">
                        <i class="fa-solid fa-microphone text-rose-400 mb-2 text-lg"></i>
                        <p class="font-semibold text-white text-sm">Eventos</p>
                        <p class="text-[11px] text-slate-500 mt-0.5">Palestras e workshops</p>
                    </div>
                </div>

                <button type="button" onclick="prevStep(1)" class="btn-back">
                    <i class="fa-solid fa-arrow-left"></i> Voltar
                </button>
            </div>

            <!-- ===== STEP 3: ASSESSORIA — morar ou investir ===== -->
            <div class="step" data-step="3">
                <h2 class="text-2xl font-bold mb-2 text-white">Qual o seu objetivo?</h2>
                <p class="text-slate-400 mb-6 text-sm">Isso ajuda a filtrar as melhores oportunidades para você.</p>

                <div class="grid grid-cols-2 gap-4 mb-8">
                    <label class="option-pill" onclick="selectObjetivo(this, 'morar')">
                        <input type="radio" name="_objetivo_ui" class="hidden">
                        <div class="text-3xl mb-3">🏠</div>
                        <p class="font-bold text-white">Morar</p>
                        <p class="text-xs text-slate-400 mt-1">Busco minha casa própria com desconto</p>
                    </label>
                    <label class="option-pill" onclick="selectObjetivo(this, 'investir')">
                        <input type="radio" name="_objetivo_ui" class="hidden">
                        <div class="text-3xl mb-3">📈</div>
                        <p class="font-bold text-white">Investir</p>
                        <p class="text-xs text-slate-400 mt-1">Quero revender ou alugar para lucrar</p>
                    </label>
                </div>

                <button type="button" onclick="prevStep(2)" class="btn-back">
                    <i class="fa-solid fa-arrow-left"></i> Voltar
                </button>
            </div>

            <!-- ===== STEP 4: CAPITAL (só Assessoria) ===== -->
            <div class="step" data-step="4">
                <div id="capitalInvestirBlock">
                    <h2 class="text-2xl font-bold mb-1 text-white">Qual sua faixa de capital?</h2>
                    <p class="text-slate-400 mb-5 text-sm">Selecione o valor aproximado disponível para investir.</p>
                    <div class="space-y-3 mb-6">
                        <div class="product-card compact-range" onclick="selectCapital(this, '0-50000', '0 a 50 mil')">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-lg bg-slate-700 flex items-center justify-center flex-shrink-0">
                                    <i class="fa-solid fa-seedling text-green-400 text-sm"></i>
                                </div>
                                <div>
                                    <p class="font-semibold text-white text-sm">Até R$ 50.000</p>
                                    <p class="text-[11px] text-slate-500">Entrada inicial</p>
                                </div>
                            </div>
                        </div>
                        <div class="product-card compact-range" onclick="selectCapital(this, '50000-100000', '50 mil a 100 mil')">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-lg bg-slate-700 flex items-center justify-center flex-shrink-0">
                                    <i class="fa-solid fa-chart-line text-blue-400 text-sm"></i>
                                </div>
                                <div>
                                    <p class="font-semibold text-white text-sm">R$ 50.000 a R$ 100.000</p>
                                    <p class="text-[11px] text-slate-500">Perfil intermediário</p>
                                </div>
                            </div>
                        </div>
                        <div class="product-card compact-range" onclick="selectCapital(this, '100000-1000000', '100 mil a 1 milhão')">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-lg bg-slate-700 flex items-center justify-center flex-shrink-0">
                                    <i class="fa-solid fa-coins text-amber-400 text-sm"></i>
                                </div>
                                <div>
                                    <p class="font-semibold text-white text-sm">R$ 100.000 a R$ 1.000.000</p>
                                    <p class="text-[11px] text-slate-500">Investidor ativo</p>
                                </div>
                            </div>
                        </div>
                        <div class="product-card compact-range" onclick="selectCapital(this, '1000000+', 'Acima de 1 milhão')">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-lg bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
                                    <i class="fa-solid fa-crown text-yellow-400 text-sm"></i>
                                </div>
                                <div>
                                    <p class="font-semibold text-white text-sm">Acima de R$ 1.000.000</p>
                                    <p class="text-[11px] text-slate-500">Investidor de alto volume</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="capitalMorarBlock" class="hidden">
                    <h2 class="text-2xl font-bold mb-1 text-white">Quanto você tem disponível?</h2>
                    <p class="text-slate-400 mb-5 text-sm">Informe o valor total para compra ou entrada.</p>
                    <div class="relative mb-6">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 font-bold">R$</span>
                        <input type="text" id="capitalMorarInput" 
                            class="w-full bg-slate-900 border border-slate-800 rounded-2xl py-4 pl-12 pr-4 text-white font-bold text-xl focus:ring-2 focus:ring-yellow-500/50 outline-none transition-all placeholder:text-slate-700"
                            placeholder="0,00"
                            oninput="formatCurrency(this)">
                    </div>
                    <button type="button" onclick="confirmCapitalMorar()" class="btn-gold">
                        Continuar <i class="fa-solid fa-arrow-right ml-2"></i>
                    </button>
                </div>

                <button type="button" onclick="prevStep(3)" class="btn-back mt-4">
                    <i class="fa-solid fa-arrow-left"></i> Voltar
                </button>
            </div>

            <!-- ===== STEP 5: CONTATO ===== -->
            <div class="step" data-step="5">
                <h2 class="text-2xl font-bold mb-2 text-white">Quase lá!</h2>
                <p class="text-slate-400 mb-6 text-sm">Preencha seus dados para entrarmos em contato.</p>

                <div class="space-y-4 mb-6">
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Seu Nome</label>
                        <input type="text" name="nome" class="field-input" placeholder="Ex: João da Silva" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Estado</label>
                        <select name="estado" class="field-input" required style="appearance: none; cursor: pointer;">
                            <option value="" disabled selected>Selecione seu estado...</option>
                            <option value="AC">Acre (AC)</option>
                            <option value="AL">Alagoas (AL)</option>
                            <option value="AP">Amapá (AP)</option>
                            <option value="AM">Amazonas (AM)</option>
                            <option value="BA">Bahia (BA)</option>
                            <option value="CE">Ceará (CE)</option>
                            <option value="DF">Distrito Federal (DF)</option>
                            <option value="ES">Espírito Santo (ES)</option>
                            <option value="GO">Goiás (GO)</option>
                            <option value="MA">Maranhão (MA)</option>
                            <option value="MT">Mato Grosso (MT)</option>
                            <option value="MS">Mato Grosso do Sul (MS)</option>
                            <option value="MG">Minas Gerais (MG)</option>
                            <option value="PA">Pará (PA)</option>
                            <option value="PB">Paraíba (PB)</option>
                            <option value="PR">Paraná (PR)</option>
                            <option value="PE">Pernambuco (PE)</option>
                            <option value="PI">Piauí (PI)</option>
                            <option value="RJ">Rio de Janeiro (RJ)</option>
                            <option value="RN">Rio Grande do Norte (RN)</option>
                            <option value="RS">Rio Grande do Sul (RS)</option>
                            <option value="RO">Rondônia (RO)</option>
                            <option value="RR">Roraima (RR)</option>
                            <option value="SC">Santa Catarina (SC)</option>
                            <option value="SP">São Paulo (SP)</option>
                            <option value="SE">Sergipe (SE)</option>
                            <option value="TO">Tocantins (TO)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Cidade</label>
                        <input type="text" name="cidade" class="field-input" placeholder="Ex: Fortaleza" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">WhatsApp</label>
                        <input type="tel" name="whatsapp" id="whatsappInput" class="field-input" placeholder="(00) 00000-0000" required>
                    </div>
                </div>

                <!-- Resumo do que selecionou -->
                <div id="summaryBox" class="bg-yellow-500/5 border border-yellow-500/20 rounded-xl p-4 mb-6">
                    <p class="text-xs font-semibold text-yellow-500/80 uppercase tracking-wider mb-2">Seu interesse</p>
                    <p id="summaryText" class="text-white font-medium text-sm"></p>
                </div>

                <button type="submit" id="btnSubmit" class="btn-gold">
                    <span id="btnText">Enviar meu cadastro <i class="fa-solid fa-paper-plane ml-2"></i></span>
                    <span id="btnSpinner" class="hidden"><i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Enviando...</span>
                </button>

                <button type="button" onclick="prevStep(getContactPrevStep())" class="btn-back mt-4 w-full justify-center">
                    <i class="fa-solid fa-arrow-left"></i> Voltar
                </button>
            </div>

            <!-- ===== STEP SUCCESS ===== -->
            <div class="step" data-step="success">
                <div class="text-center">
                    <div class="w-20 h-20 bg-green-500/10 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="fa-solid fa-check text-4xl text-green-400"></i>
                    </div>
                    <h2 class="text-3xl font-extrabold mb-3 text-white">Cadastro Recebido!</h2>
                    <p class="text-slate-400 mb-8 max-w-xs mx-auto">Nossa equipe vai analisar seu perfil e entrar em contato em breve pelo WhatsApp.</p>

                    <div class="bg-slate-800/60 border border-slate-700 rounded-2xl p-5 mb-8 max-w-sm mx-auto text-left">
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Seu Score de Qualificação</p>
                        <div class="w-full h-3 bg-slate-700 rounded-full overflow-hidden mb-2">
                            <div id="scoreBar" class="h-full bg-gradient-to-r from-yellow-400 to-green-400 w-0 transition-all duration-1000"></div>
                        </div>
                        <p id="scoreText" class="text-right text-xs text-yellow-500 font-bold">Calculando...</p>
                    </div>

                    <a href="https://instagram.com/paulinhodosleiloes" target="_blank"
                        class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors text-sm">
                        <i class="fa-brands fa-instagram text-rose-400"></i> Seguir no Instagram
                    </a>
                </div>
            </div>

        </form>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
<script>
// =============================================
// STATE
// =============================================
let currentStep = 1;
let selectedInteresse = '';
let selectedObjetivo = '';
let selectedCapital = '';
const TOTAL_STEPS = 5;

// =============================================
// NAVIGATION
// =============================================
function showStep(n) {
    document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
    const el = document.querySelector(`[data-step="${n}"]`);
    if (el) el.classList.add('active');
    currentStep = typeof n === 'number' ? n : 0;
    updateProgress();
}

function nextStep(n) { showStep(n); }
function prevStep(n) { showStep(n); }

// Volta do step de contato (5)
function getContactPrevStep() {
    if (selectedInteresse === 'assessoria') return 4; // volta para capital
    return 2; // licenciado/promotor/outros voltam para seleção de interesse
}

function updateProgress() {
    const stepNum = currentStep === 'success' ? TOTAL_STEPS : (typeof currentStep === 'number' ? currentStep : TOTAL_STEPS);
    const pct = Math.round((stepNum / TOTAL_STEPS) * 100);
    document.getElementById('progressBar').style.width = pct + '%';
}

// =============================================
// INTEREST SELECTION
// =============================================
function selectInteresse(card, value) {
    document.querySelectorAll('.product-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    selectedInteresse = value;
    document.getElementById('interesseInput').value = value;

    setTimeout(() => {
        if (value === 'assessoria') {
            nextStep(3); // Assessoria → morar/investir
        } else {
            // Licenciado, Promotor, Mentoria, Eventos → direto para contato
            selectedObjetivo = '';
            selectedCapital = '';
            document.getElementById('objetivoInput').value = '';
            updateSummary();
            nextStep(5);
        }
    }, 250);
}

// =============================================
// OBJETIVO (morar/investir) — só Assessoria
// =============================================
function selectObjetivo(pill, value) {
    document.querySelectorAll('.option-pill').forEach(p => p.classList.remove('selected'));
    pill.classList.add('selected');
    selectedObjetivo = value;
    document.getElementById('objetivoInput').value = value;

    setTimeout(() => {
        // Mostra bloco correto no step 4
        document.getElementById('capitalInvestirBlock').classList.toggle('hidden', value !== 'investir');
        document.getElementById('capitalMorarBlock').classList.toggle('hidden', value !== 'morar');
        // Reseta seleções de faixas
        document.querySelectorAll('.compact-range').forEach(c => c.classList.remove('selected'));
        document.getElementById('capitalMorarInput').value = '';
        selectedCapital = '';
        nextStep(4);
    }, 250);
}

// =============================================
// CAPITAL — Investidor (faixas)
// =============================================
function selectCapital(card, value, label) {
    document.querySelectorAll('.compact-range').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    selectedCapital = value;
    setTimeout(() => {
        updateSummary();
        nextStep(5);
    }, 250);
}

// =============================================
// CAPITAL — Morar (campo livre)
// =============================================
function confirmCapitalMorar() {
    const val = document.getElementById('capitalMorarInput').value.trim();
    if (!val) { alert('Informe o valor disponível.'); return; }
    selectedCapital = val;
    updateSummary();
    nextStep(5);
}

// =============================================
// SUMMARY BOX
// =============================================
const LABELS = {
    assessoria: 'Assessoria Imobiliária',
    mentoria_online: 'Mentoria Online',
    mentoria_individual: 'Mentoria Individual',
    licenciado: 'Licenciado',
    promotor: 'Promotor Oficial',
    eventos: 'Eventos e Palestras'
};
const OBJ_LABELS = { morar: 'para Morar', investir: 'para Investir' };

function updateSummary() {
    let text = LABELS[selectedInteresse] || selectedInteresse;
    if (selectedInteresse === 'assessoria' && selectedObjetivo) {
        text += ' — ' + OBJ_LABELS[selectedObjetivo];
        if (selectedCapital) text += ' · R$ ' + selectedCapital.replace('0-50000','Até 50k').replace('50000-100000','50k–100k').replace('100000-1000000','100k–1M').replace('1000000+','1M+');
    }
    document.getElementById('summaryText').textContent = text;
}

// =============================================
// FORM SUBMIT
// =============================================
document.getElementById('funnelForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    // Validation
    const nome = document.querySelector('[name="nome"]').value.trim();
    const cidade = document.querySelector('[name="cidade"]').value.trim();
    const whatsapp = document.querySelector('[name="whatsapp"]').value.trim();

    if (!nome || !cidade || !whatsapp) {
        alert('Por favor, preencha todos os campos.');
        return;
    }
    if (!selectedInteresse) {
        alert('Por favor, selecione um interesse.');
        return;
    }

    // UI loading
    document.getElementById('btnText').classList.add('hidden');
    document.getElementById('btnSpinner').classList.remove('hidden');
    document.getElementById('btnSubmit').disabled = true;

    // Resolve capital numérico para o backend
    let capitalNum = 0;
    if (selectedCapital === '0-50000')          capitalNum = 25000;
    else if (selectedCapital === '50000-100000') capitalNum = 75000;
    else if (selectedCapital === '100000-1000000') capitalNum = 550000;
    else if (selectedCapital === '1000000+')    capitalNum = 1500000;
    else if (selectedCapital) capitalNum = parseFloat(selectedCapital.replace(/[^0-9]/g, '')) || 0;

    const formData = {
        nome,
        cidade,
        whatsapp,
        interesse: selectedInteresse,
        objetivo: selectedObjetivo || 'nao_informado',
        capital_disponivel: capitalNum,
        // legacy fields
        experiencia: 'primeira_vez',
        restricao_nome: 'false',
        preferencia_pgto: selectedObjetivo === 'investir' ? 'vista' : 'nao_informado',
        estado: '',
        fingerprint: window._fp || ''
    };

    try {
        const res = await fetch('/api/leads/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        });
        const data = await res.json();

        if (data.success) {
            showStep('success');
            // Animate score bar
            setTimeout(() => {
                const score = data.score || 50;
                document.getElementById('scoreBar').style.width = score + '%';
                document.getElementById('scoreText').textContent = score + ' / 100';
            }, 300);
        } else {
            throw new Error(data.error || 'Erro desconhecido');
        }
    } catch (err) {
        console.error(err);
        document.getElementById('btnText').classList.remove('hidden');
        document.getElementById('btnSpinner').classList.add('hidden');
        document.getElementById('btnSubmit').disabled = false;
        alert('Ocorreu um erro. Tente novamente.');
    }
});

// =============================================
// MASKS
// =============================================
$(document).ready(function() {
    $('#whatsappInput').mask('(00) 00000-0000');
});

// =============================================
// FINGERPRINT (simple)
// =============================================
window._fp = btoa([navigator.userAgent, screen.width, screen.height, navigator.language].join('|')).substring(0, 32);
// =============================================
// ANIMATED COUNTERS (primeiros 3 segundos)
// =============================================
function animateCounter(el, target, duration, suffix) {
    const start = performance.now();
    const update = (time) => {
        const elapsed = time - start;
        const progress = Math.min(elapsed / duration, 1);
        // easeOutExpo
        const ease = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
        const value = Math.round(ease * target);
        el.textContent = value >= 1000 ? '1000+' : value + (value === target ? suffix : '');
        if (progress < 1) requestAnimationFrame(update);
        else el.textContent = '1000+';
    };
    requestAnimationFrame(update);
}

function formatCurrency(input) {
    let value = input.value.replace(/\D/g, '');
    value = (value / 100).toLocaleString('pt-BR', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
    input.value = value;
    selectedCapital = value;
}

window.addEventListener('load', () => {
    setTimeout(() => {
        const elAlunos   = document.getElementById('countAlunos');
        const elArremates = document.getElementById('countArremates');
        if (elAlunos)    animateCounter(elAlunos,    1000, 1800, '+');
        if (elArremates) animateCounter(elArremates, 1000, 2000, '+');
    }, 300);
});
</script>
</body>
</html>
<script>
    // Sistema de Navegação PJAX Avançado (Premium macOS Experience)
    document.addEventListener('DOMContentLoaded', () => {
        if (window.sidebarPjaxInitialized) return;
        window.sidebarPjaxInitialized = true;

        const mainSelector = '.macos-main-content';
        const sidebarItems = document.querySelectorAll('.macos-sidebar-item');

        const updateActiveState = () => {
            const currentPath = window.location.pathname;
            sidebarItems.forEach(item => {
                const href = item.getAttribute('href');
                const isActive = href === currentPath || (href !== '/' && currentPath.startsWith(href));
                item.classList.toggle('active', isActive);
            });
        };

        const loadPage = async (url, pushToHistory = true) => {
            const mainContent = document.querySelector(mainSelector);
            if (!mainContent) {
                window.location.href = url;
                return;
            }

            // Iniciar animação de transição (Sutil e Rápida)
            mainContent.style.transition = 'opacity 0.12s ease-out, transform 0.12s ease-out';
            mainContent.style.opacity = '0.4'; // Don't go to full 0 to avoid white flash
            mainContent.style.transform = 'scale(0.995)';

            try {
                // Fetch do conteúdo
                const response = await fetch(url);
                if (!response.ok) throw new Error('Falha na resposta do servidor');
                
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                const newContent = doc.querySelector(mainSelector);
                const newTitle = doc.querySelector('title');
                
                if (newContent) {
                    // Sincronizar com o fim da animação de saída
                    await new Promise(r => setTimeout(r, 100));

                    // Limpar estilos de páginas anteriores injetados via PJAX
                    document.querySelectorAll('.pjax-dynamic-style').forEach(el => el.remove());

                    // Injetar novos estilos
                    const newStyles = doc.querySelectorAll('style, link[rel="stylesheet"]');
                    newStyles.forEach(style => {
                        const isLink = style.tagName === 'LINK';
                        const href = isLink ? style.getAttribute('href') : null;
                        
                        // Se for um link, verifica se já existe no head original
                        if (isLink && document.querySelector(`link[href="${href}"]:not(.pjax-dynamic-style)`)) return;
                        
                        const styleClone = style.cloneNode(true);
                        styleClone.classList.add('pjax-dynamic-style');
                        document.head.appendChild(styleClone);
                    });

                    // Atualizar o DOM
                    mainContent.innerHTML = newContent.innerHTML;
                    if (newTitle) document.title = newTitle.textContent;
                    
                    // Gerenciar Histórico
                    if (pushToHistory) {
                        window.history.pushState({ pjax: true }, '', url);
                    }
                    
                    // Atualizar UI Global
                    updateActiveState();
                    if (window.initMacOSUI) window.initMacOSUI();
                    
                    // Executar scripts da nova página
                    const scripts = newContent.querySelectorAll('script');
                    scripts.forEach(oldScript => {
                        const newScript = document.createElement('script');
                        Array.from(oldScript.attributes).forEach(attr => {
                            if (attr.name !== 'src') newScript.setAttribute(attr.name, attr.value);
                        });
                        
                        if (oldScript.src) {
                            newScript.src = oldScript.src;
                        } else {
                            newScript.textContent = oldScript.innerHTML;
                        }
                        
                        document.body.appendChild(newScript);
                        // Remover script injetado para manter o DOM limpo (apenas inline)
                        if (newScript.parentNode && !newScript.src) newScript.parentNode.removeChild(newScript);
                    });

                    // Scroll Reset
                    window.scrollTo({ top: 0, behavior: 'instant' });

                    // Finalizar animação (Entrada suave)
                    requestAnimationFrame(() => {
                        mainContent.style.opacity = '1';
                        mainContent.style.transform = 'scale(1) translateY(0)';
                    });
                } else {
                    // Fallback para recarregamento total se o seletor não for encontrado
                    window.location.href = url;
                }
            } catch (err) {
                console.error('PJAX Error:', err);
                window.location.href = url;
            }
        };

        // Delegação de eventos para capturar todos os cliques em links locais
        document.body.addEventListener('click', (e) => {
            // Ignora se o clique foi com teclas de modificação
            if (e.ctrlKey || e.shiftKey || e.metaKey || e.button !== 0) return;

            const link = e.target.closest('a');
            if (!link) return;

            const href = link.getAttribute('href');
            const target = link.getAttribute('target');

            // Critérios para INTERCEPTAR via PJAX:
            // 1. Link local (não começa com http/https)
            // 2. Não é âncora interna (#)
            // 3. Não tem target="_blank"
            // 4. Não é um link de sistema (mailto, tel, javascript)
            // 5. Não tem o atributo data-pjax="false"
            
            const isLocal = href && !href.match(/^https?:\/\//) && !href.startsWith('//');
            const isAnchor = href && href.startsWith('#');
            const isBlank = target === '_blank';
            const isSystem = href && (href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('javascript:'));
            const isDisabled = link.hasAttribute('data-pjax-false');

            if (isLocal && !isAnchor && !isBlank && !isSystem && !isDisabled) {
                e.preventDefault();
                loadPage(href);
            }
        });

        // Lidar com navegação via botões Voltar/Avançar
        window.addEventListener('popstate', (e) => {
            // Se o estado indicar que foi uma navegação PJAX ou se quisermos forçar SPA no histórico
            loadPage(window.location.pathname, false);
        });

        updateActiveState();
    });
</script>
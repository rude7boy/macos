<!-- ============================================
     🍎 macOS Toolbar (Barra Superior)
     ============================================ -->
<div class="macos-toolbar">
    <div class="macos-toolbar-left">
        <!-- Traffic Lights (Botões de Controle) -->
        <div class="macos-traffic-lights">
            <div class="macos-traffic-light close"></div>
            <div class="macos-traffic-light minimize"></div>
            <div class="macos-traffic-light maximize"></div>
        </div>

        <!-- Título da Página -->
        <div style="display: flex; align-items: center; gap: 8px; margin-left: 12px;">
            <i class="fa-solid fa-layer-group" style="font-size: 18px; color: var(--macos-text-secondary);"></i>
            <h1 id="macosPageTitle" class="macos-window-title" style="text-align: left; flex: none; margin: 0;">
                <%= typeof title !=='undefined' ? title : 'Plataforma' %>
            </h1>
        </div>
    </div>

    <div class="macos-toolbar-center">
        <!-- Barra de Busca (Opcional) -->
    </div>

    <style>
        .macos-toolbar-icon-btn {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            /* Soft rounded square */
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--macos-text-secondary);
            background: transparent;
            border: 1px solid transparent;
            /* Prevents layout shift */
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
            font-size: 14px;
        }

        .macos-toolbar-icon-btn:hover {
            background: var(--macos-bg-tertiary);
            color: var(--macos-text-primary);
            border-color: var(--macos-border);
        }

        /* Active/Checked State for Toggle */
        .macos-toolbar-icon-btn.active {
            color: var(--macos-accent);
            background: var(--macos-bg-tertiary);
        }
    </style>

    <div class="macos-toolbar-right" style="gap: 8px;">
        <!-- (Botão de Busca removido para evitar ghost button) -->

        <!-- Toggle Tema (Light/Dark) -->
        <label for="macos-theme-toggle" class="macos-toolbar-icon-btn" title="Alternar Tema">
            <input type="checkbox" id="macos-theme-toggle" style="display: none;">
            <i id="macos-theme-icon-dark" class="fa-solid fa-moon"></i>
            <i id="macos-theme-icon-light" class="fa-solid fa-sun" style="display: none; color: #F59E0B;"></i>
        </label>

        <!-- (Profile Dropdown Removido - Sistema de Login Desativado) -->
    </div>
</div>

<script type="module">
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.3/+esm';
    const SUPABASE_URL = <%= JSON.stringify(typeof supabaseUrl !== 'undefined' ? supabaseUrl : '') %>;
    const SUPABASE_ANON_KEY = <%= JSON.stringify(typeof supabaseAnonKey !== 'undefined' ? supabaseAnonKey : '') %>;

    // Theme Toggle Logic
    const themeToggle = document.getElementById('macos-theme-toggle');
    const iconDark = document.getElementById('macos-theme-icon-dark');
    const iconLight = document.getElementById('macos-theme-icon-light');

    if (themeToggle && iconDark && iconLight) {
        const applyTheme = (theme) => {
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
                document.documentElement.classList.remove('light');
                themeToggle.checked = false;
                iconDark.style.display = 'block';
                iconLight.style.display = 'none';
            } else {
                document.documentElement.classList.remove('dark');
                document.documentElement.classList.add('light');
                themeToggle.checked = true;
                iconDark.style.display = 'none';
                iconLight.style.display = 'block';
            }
            localStorage.setItem('theme', theme);
        };

        const savedTheme = localStorage.getItem('theme') || 'dark';
        applyTheme(savedTheme);

        themeToggle.addEventListener('change', () => {
            applyTheme(themeToggle.checked ? 'light' : 'dark');
        });
    }

    // Logout Logic (Removido - Sistema de Login Desativado)
</script>